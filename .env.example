PORT=5000
NODE_ENV=development
USE_MONGODB=true
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=ummah_travel_local

# Public API base URL for absolute media links (no trailing slash)
PUBLIC_API_BASE_URL=http://localhost:5000

# CORS (comma-separated list, use * only if you understand the security tradeoff)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_CREDENTIALS=true

# JWT
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRE=7d

# Admin account (set either ADMIN_PASSWORD_HASH or ADMIN_PASSWORD)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@ummahtravel.com
ADMIN_PASSWORD_HASH=
# ADMIN_PASSWORD=ChangeMe123!

# Optional third-party integrations (managed from admin panel)
AMADEUS_API_KEY=
HOTELBEDS_API_KEY=
STRIPE_SECRET_KEY=
TWILIO_AUTH_TOKEN=
SENDGRID_API_KEY=
GOOGLE_MAPS_API_KEY=
EXCHANGERATE_API_KEY=
OPENWEATHER_API_KEY=
